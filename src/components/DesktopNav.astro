---
import profile from '../data/profile.en.json';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';
---

<!-- Desktop Navigation Bar -->
<nav
  class="fixed top-0 left-0 right-0 z-50 bg-miku-surface/80 dark:bg-miku-dark-surface/80 backdrop-blur-md border-b border-miku-cyan/20 dark:border-miku-cyan/20"
>
  <div class="container mx-auto px-4 sm:px-8 lg:px-12">
    <div class="flex justify-between items-center h-[70px]">
      <!-- Logo -->
      <a href="#" aria-label="Go to home">
        <div class="flex items-center">
          <span class="font-mono text-xl font-bold tracking-tighter text-miku-cyan dark:text-miku-cyan">
            &lt; WillyDev /&gt;
          </span>
        </div>
      </a>

      <!-- Navigation Links -->
      <div class="flex items-center gap-3">
        <div class="hidden md:flex gap-6 items-center">
          {
            profile.navigation.map(section => (
              <a
                href={`#${section.id}`}
                class="text-sm font-medium text-[#374151] dark:text-miku-dark-dim hover:text-miku-cyan transition-colors duration-300"
                data-lang-key={`nav-${section.id}`}
              >
                {section.label}
              </a>
            ))
          }
        </div>
        <div class="flex items-center gap-2">
          <span
            class="hidden xl:flex items-center gap-1.5 px-2.5 py-1 rounded-lg bg-green-600/10 border border-green-600/30 text-green-700 dark:bg-miku-success/10 dark:border-miku-success/30 dark:text-miku-success"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-green-600 dark:bg-miku-success animate-pulse"></span>
            <span class="text-xs font-medium">Open to Work</span>
          </span>
          <LanguageToggle />
          <ThemeToggle />
        </div>
      </div>
    </div>
  </div>
</nav>
