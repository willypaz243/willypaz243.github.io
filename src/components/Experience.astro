---
import profile from '../data/profile.json';
---

<section class="mb-16">
  <h2
    class="text-3xl font-bold mb-8 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
  >
    Professional Experience
  </h2>
  <div class="space-y-12">
    {
      profile.experience.map(exp => (
        <div class="border-l-4 border-miku-cyan dark:border-miku-glow pl-6 py-2 hover:border-miku-magenta dark:hover:border-miku-magenta transition-colors">
          <h3 class="text-2xl font-semibold text-miku-teal-strong dark:text-miku-cyan">{exp.company}</h3>
          <p class="text-lg text-miku-cyan dark:text-miku-glow mb-3">
            {exp.role} · {exp.period}
          </p>
          <ul class="list-disc list-inside space-y-3 text-miku-text-dim dark:text-miku-dark-dim">
            {exp.achievements.map(achievement => (
              <li class="hover:text-miku-text-main dark:hover:text-miku-dark-text transition-colors">{achievement}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>

