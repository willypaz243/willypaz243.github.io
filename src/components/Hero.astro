---
import profile from '../data/profile.en.json';
---

<style>
  .cursor {
    display: inline-block;
    width: 8px;
    height: 18px;
    background: var(--miku-cyan);
    animation: blink 1s infinite;
    vertical-align: middle;
    margin-left: 2px;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>

<section class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
  <div class="w-full max-w-7xl grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
    <!-- Left Column: Text Content -->
    <div class="order-2 lg:order-1 flex flex-col justify-center space-y-4 text-left lg:text-left">
      <!-- Headline (hidden on mobile) -->
      <h1 class="hidden md:block text-3xl sm:text-4xl lg:text-5xl font-bold text-miku-text-main dark:text-miku-dark-text">
        AI & Full Stack Developer
      </h1>
      <!-- Value Proposition (hidden on mobile) -->
      <p class="hidden md:block text-lg sm:text-xl text-miku-text-dim dark:text-miku-dark-dim leading-relaxed">
        I build production-ready systems for startups and scale-ups.
      </p>

      <!-- CTA Buttons -->
      <div class="flex gap-3 sm:gap-4">
        <a
          id="cta-projects"
          href="#projects"
          class="btn-primary inline-block px-6 py-2.5 bg-miku-cyan hover:bg-miku-glow text-miku-base dark:text-miku-dark-base rounded-xl transition-all duration-300 transform hover:-translate-y-1"
        >
          View My Work
        </a>
        <a
          id="cta-contact"
          href="#footer"
          class="btn-outline inline-block px-6 py-2.5 border border-gray-600 hover:border-miku-cyan hover:text-miku-cyan text-gray-300 rounded-xl transition-all duration-300 transform hover:-translate-y-1"
        >
          Contact
        </a>
      </div>

      <!-- Availability -->
      <p class="text-sm text-miku-success dark:text-[#00E676] flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-miku-success animate-pulse"></span>
        Open to full-time remote roles and consulting projects
      </p>

      <!-- About Me -->
      <div class="mt-2">
        <h2
          id="about-title"
          class="text-lg font-semibold mb-1 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
        >
          {profile.about.title}
        </h2>
        <p
          id="about-desc"
          class="text-sm text-miku-text-dim dark:text-miku-dark-dim leading-relaxed max-w-lg"
        >
          {profile.about.description}
        </p>
      </div>
    </div>

    <!-- Right Column: Terminal Window -->
    <div class="order-1 lg:order-2">
      <div class="rounded-xl overflow-hidden border-2 border-miku-cyan/30 dark:border-miku-cyan/30 shadow-2xl shadow-miku-cyan/10 dark:shadow-miku-cyan/20">
        <!-- Terminal Header -->
        <div
          class="bg-miku-surface dark:bg-miku-dark-surface px-4 py-3 flex items-center gap-2 border-b border-miku-cyan/20 dark:border-miku-cyan/20"
        >
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>

        <!-- Terminal Content -->
        <div class="bg-miku-base dark:bg-miku-dark-base p-4 sm:p-6 font-mono text-xs sm:text-sm md:text-base">
          <div id="terminal-code" class="text-miku-text-main dark:text-miku-dark-text whitespace-pre-wrap break-words min-h-[380px] lg:min-h-[500px]">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ profile }}>
  // Python code to type out
  const code = `from dataclasses import dataclass, field
from typing import List

@dataclass
class Developer:
    name: str = "${profile.personal.name}"
    role: str = "${profile.personal.title}"
    location: str = "${profile.personal.location}"
    experience_years: int = ${profile.about.experience}
    
    stack: List[str] = field(default_factory=lambda [
        "Python", "FastAPI", "LangChain",
        "React", "Docker", "AWS"
    ])
    focus: str = "RAG Systems • Scalable APIs • Cloud Infra"
    
    @property
    def available(self) -> bool:
        return True  # Open to remote work`;

  // Syntax highlighting colors (Miku palette)
  const colors = {
    keyword: '#FF0080', // MAGENTA_POP for keywords
    string: '#00E676', // FUNC_SUCCESS for strings
    number: '#48FFF4', // MIKU_GLOW for numbers
    comment: '#8B949E', // TXT_DIM for comments
    class_name: '#39C5BB', // MIKU_CYAN for class names
    function: '#7B61FF', // TECH_VIOLET for functions
    default: '#F0F6FC', // TXT_MAIN for default
  };

  // Tokenize and highlight code
  function highlightCode(code) {
    // Escape HTML first
    let result = code.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    // Token types with their patterns
    const tokens = [
      { type: 'string', pattern: /(".*?"|'.*?')/g },
      {
        type: 'keyword',
        pattern: /\b(from|import|class|def|str|int|list|return|if|else|for|while|True|False|None|@property|dataclass|field)\b/g,
      },
      { type: 'class_name', pattern: /\b([A-Z][a-zA-Z0-9_]*)\b/g },
      { type: 'number', pattern: /\b(\d+)\b/g },
    ];

    // Track which positions are already highlighted
    const highlighted = new Set();
    const parts = [];

    // Find all token matches
    const matches = [];
    tokens.forEach(token => {
      let match;
      const regex = new RegExp(token.pattern.source, token.pattern.flags);
      while ((match = regex.exec(result)) !== null) {
        matches.push({
          type: token.type,
          start: match.index,
          end: match.index + match[0].length,
          text: match[0],
        });
      }
    });

    // Sort matches by start position
    matches.sort((a, b) => a.start - b.start);

    // Build highlighted string
    let lastEnd = 0;
    matches.forEach(match => {
      // Check if this match overlaps with already highlighted content
      let overlaps = false;
      for (let i = match.start; i < match.end; i++) {
        if (highlighted.has(i)) {
          overlaps = true;
          break;
        }
      }

      if (!overlaps) {
        // Add non-highlighted text before this match
        if (match.start > lastEnd) {
          parts.push(result.substring(lastEnd, match.start));
        }

        // Add highlighted text
        const color = colors[match.type] || colors.default;
        parts.push(`<span style="color: ${color}">${match.text}</span>`);

        // Mark positions as highlighted
        for (let i = match.start; i < match.end; i++) {
          highlighted.add(i);
        }

        lastEnd = match.end;
      }
    });

    // Add remaining non-highlighted text
    if (lastEnd < result.length) {
      parts.push(result.substring(lastEnd));
    }

    return parts.join('');
  }

  // Typing animation
  async function typeCode() {
    const terminal = document.getElementById('terminal-code');
    if (!terminal) return;

    const typingSpeed = 5; // ms per character

    for (let i = 1; i <= code.length; i++) {
      const partialCode = code.substring(0, i);
      const highlighted = highlightCode(partialCode);

      // Add cursor
      terminal.innerHTML = highlighted + '<span class="cursor"></span>';

      await new Promise(resolve => setTimeout(resolve, typingSpeed));
    }

    // Remove cursor after typing completes
    setTimeout(() => {
      const cursor = terminal.querySelector('.cursor');
      if (cursor) cursor.remove();
    }, 2000);
  }

  // Start animation when component loads
  typeCode();
</script>
