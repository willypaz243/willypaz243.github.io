---
import profile from '../data/profile.json';
---

<section class="mb-16 animate-fade-in">
  <div class="mb-6">
    <span
      class="text-miku-teal-strong dark:text-miku-glow font-medium text-lg tracking-wide inline-block py-2 px-4 rounded-full bg-miku-cyan/10 dark:bg-miku-magenta/10 border border-miku-cyan/20 dark:border-miku-magenta/20 transition-all duration-300 hover:border-miku-cyan/50 dark:hover:border-miku-magenta/50 hover:shadow-miku-dark dark:hover:shadow-miku-neon"
    >
      {profile.personal.title}
    </span>
  </div>
  <h1
    class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text leading-tight transition-all duration-300 hover:from-miku-teal-strong dark:hover:from-miku-cyan hover:to-miku-glow dark:hover:to-miku-magenta"
  >
    {profile.personal.name}
  </h1>
  <div class="text-miku-text-dim dark:text-miku-dark-dim mb-8 text-lg">
    <p class="flex flex-wrap gap-2 items-center">
      <span class="flex items-center">
        <svg fill="currentColor" class="w-5 h-5 mr-1 text-miku-cyan dark:text-miku-glow" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 1 1 9.9 9.9L10 18.9l-4.95-4.95a7 7 0 0 1 0-9.9M10 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4" clip-rule="evenodd"/></svg>
        {profile.personal.location}
      </span>
      <span class="text-miku-text-dim dark:text-miku-dark-dim">·</span>
      <a
        href={profile.personal.linkedin}
        class="flex items-center text-miku-cyan dark:text-miku-glow hover:text-miku-teal-strong dark:hover:text-miku-magenta hover:underline transition-colors duration-300"
      >
        <svg class="w-5 h-5 mr-1 text-miku-cyan dark:text-miku-glow" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
          ></path>
        </svg>
        LinkedIn
      </a>
      <span class="text-miku-text-dim dark:text-miku-dark-dim">·</span>
      <a
        href={profile.personal.github}
        class="flex items-center text-miku-cyan dark:text-miku-glow hover:text-miku-teal-strong dark:hover:text-miku-magenta hover:underline transition-colors duration-300"
      >
        <svg class="w-5 h-5 mr-1 text-miku-cyan dark:text-miku-glow" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.673-.217.673-.483 0-.237-.008-.867-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.905-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.657.341-1.088.61-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.987 1.028-2.687-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.295 2.747-1.026 2.747-1.026.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.687 0 3.841-2.339 4.687-4.566 4.934.359.309.678.92.678 1.855 0 1.337-.012 2.417-.012 2.744 0 .267.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          ></path>
        </svg>
        GitHub
      </a>
      <span class="text-miku-text-dim dark:text-miku-dark-dim">·</span>
      <a
        href={`mailto:${profile.personal.email}`}
        class="flex items-center text-miku-cyan dark:text-miku-glow hover:text-miku-teal-strong dark:hover:text-miku-magenta hover:underline transition-colors duration-300"
      >
        <svg class="w-5 h-5 mr-1 text-miku-cyan dark:text-miku-glow" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
          <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
        </svg>
        Email
      </a>
    </p>
  </div>
  <div class="flex gap-4 mt-8">
    <a
      href={`mailto:${profile.personal.email}`}
      class="px-8 py-3 rounded-miku bg-miku-cyan dark:bg-miku-cyan text-white dark:text-miku-text-main font-semibold hover:bg-miku-glow dark:hover:bg-miku-cyan hover:shadow-miku-neon dark:hover:shadow-miku-dark transition-all duration-300 transform hover:-translate-y-1"
    >
      Get in Touch
    </a>
    <a
      href="#experience"
      class="px-8 py-3 rounded-miku border-2 border-miku-cyan dark:border-miku-magenta text-miku-cyan dark:text-miku-magenta font-semibold hover:bg-miku-cyan/10 dark:hover:bg-miku-magenta/10 hover:shadow-miku-light dark:hover:shadow-miku-neon transition-all duration-300 transform hover:-translate-y-1"
    >
      View Experience
    </a>
  </div>
</section>

