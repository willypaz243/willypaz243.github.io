---
// LanguageToggle — client-side component for ES/EN switching
---

<!-- Language Toggle Button -->
<button
  id="language-toggle"
  class="text-sm font-medium px-3 py-1.5 rounded-lg border border-miku-cyan/30 text-miku-cyan hover:bg-miku-cyan/10 transition-colors duration-300"
  aria-label="Switch language"
>
  <span id="lang-label">ES</span>
</button>

<script is:inline>
  (() => {
    function getLang() {
      return localStorage.getItem('lang') || 'en';
    }
    function setLang(lang) {
      localStorage.setItem('lang', lang);
      document.documentElement.lang = lang;
    }

    const btn = document.getElementById('language-toggle');
    const label = document.getElementById('lang-label');
    if (!btn || !label) return;

    function updateLabel() {
      label.textContent = getLang() === 'en' ? 'ES' : 'EN';
    }

    btn.addEventListener('click', () => {
      const current = getLang();
      const next = current === 'en' ? 'es' : 'en';
      setLang(next);
      updateLabel();
      if (typeof window.switchLanguage === 'function') window.switchLanguage(next);
    });

    // Restore from localStorage
    const saved = getLang();
    if (saved !== 'en') setLang(saved);
    updateLabel();
  })();
</script>

<style>
  #language-toggle:focus-visible {
    outline: 2px solid #06b6d4;
    outline-offset: 2px;
  }
</style>
