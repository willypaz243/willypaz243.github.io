---
import profile from '../data/profile.json';
---

<!-- Desktop Navigation -->
<nav class="fixed left-4 top-1/2 -translate-y-1/2 z-50 hidden lg:block">
  <ul class="space-y-4">
    {
      profile.navigation.map(section => (
        <li>
          <a href={`#${section.id}`} class="flex items-center group">
            <span class="w-10 h-10 flex items-center justify-center rounded-full bg-miku-base dark:bg-miku-dark-surface border-2 border-miku-dark-border group-hover:border-miku-cyan group-hover:shadow-miku-neon transition-all duration-300 transform -translate-x-4 group-hover:translate-x-0">
              {section.icon}
            </span>
            <span class="opacity-0 group-hover:opacity-100 pl-3 text-miku-teal-strong dark:text-miku-cyan transition-opacity dark:group-hover:text-miku-glow">
              {section.label}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<!-- Mobile Navigation -->
<nav class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 lg:hidden">
  <ul class="flex gap-2 p-2 bg-miku-surface dark:bg-miku-dark-surface rounded-full shadow-miku-light">
    {
      profile.navigation.map(section => (
        <li>
          <a
            href={`#${section.id}`}
            class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-miku-cyan/10 dark:hover:bg-miku-cyan/20 transition-colors dark:hover:shadow-miku-dark"
            title={section.label}
          >
            {section.icon}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

