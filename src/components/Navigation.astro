---
import profile from '../data/profile.json';
---

<!-- Mobile Navigation Bar -->
<nav class="fixed bottom-4 left-1/2 -translate-x-1/2 z-50 md:hidden">
  <ul class="flex gap-2 p-2 lg:gap-3 lg:p-3 bg-miku-surface dark:bg-miku-dark-surface rounded-full lg:rounded-xl shadow-miku-light">
    {
      profile.navigation.map(section => (
        <li>
          <a
            href={`#${section.id}`}
            class="w-10 h-10 lg:w-12 lg:h-12 flex items-center justify-center rounded-full lg:rounded-xl hover:bg-miku-cyan/10 dark:hover:bg-miku-cyan/20 text-miku-text-main dark:text-miku-dark-text transition-colors dark:hover:shadow-miku-dark group relative"
            title={section.label}
          >
            {section.icon}

            <!-- Tooltip (visible on hover) -->
            <span class="absolute -top-12 left-1/2 -translate-x-1/2 px-2 py-1 text-xs text-miku-text-main dark:text-miku-dark-text bg-miku-surface dark:bg-miku-dark-surface border border-miku-cyan dark:border-miku-cyan rounded-lg opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
              {section.label}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

  <h2
    class="text-center text-3xl font-bold mb-8 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
  >
    Professional Experience
  </h2>
  <div class="space-y-12">
    <div class="absolute left-0 top-0 h-full w-0.5 bg-miku-cyan/20 dark:bg-miku-cyan/10"></div>
    {
      profile.experience.map(exp => (
        <div class="border-l-4 border-miku-cyan dark:border-miku-glow pl-6 py-2 hover:border-miku-magenta dark:hover:border-miku-magenta transition-colors">
          <h3 class="text-2xl font-semibold text-miku-teal-strong dark:text-miku-cyan">{exp.role}</h3>
          <p class="text-sm font-medium text-miku-text-dim dark:text-miku-dark-dim mb-2">{exp.company}</p>
          <p class="text-xs font-mono text-miku-cyan mb-6 inline-block bg-miku-cyan/10 px-2 py-1 rounded">
            {exp.period}
          </p>
          <ul class="list-disc list-inside space-y-2 text-miku-text-dim dark:text-miku-dark-dim">
            {exp.achievements.map(achievement => (
              <li class="hover:text-miku-text-main dark:hover:text-miku-dark-text transition-colors">{achievement}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
