---
import profile from '../data/profile.en.json';

// Determine if a link is a live demo (not GitHub)
function isLiveDemo(link: string): boolean {
  return link !== '#' && !link.includes('github.com');
}
---

<section class="mb-16">
  <h2
    id="proj-title"
    data-animate
    class="text-3xl font-bold mb-8 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
  >
    Featured Projects
  </h2>
  <div data-animate-stagger class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {
      profile.projects
        .filter(p => p.link !== '#')
        .map(project => (
          <article
            data-animate
            class="group relative p-6 rounded-miku bg-miku-surface dark:bg-miku-dark-surface shadow-miku-light dark:shadow-none transition-all duration-300 transform hover:-translate-y-1 border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-cyan/50"
          >
            {/* Project Title */}
            <h3 class="text-2xl font-semibold mb-2 text-miku-teal-strong dark:text-miku-cyan">
              {project.title}
            </h3>

            {/* Description */}
            <p class="text-miku-text-dim dark:text-miku-dark-dim mb-4 leading-relaxed text-sm">
              {project.description}
            </p>

            {/* Tech Stack Badges */}
            <div class="flex flex-wrap gap-1.5 mb-5">
              {project.technologies.map(tech => (
                <span class="px-2.5 py-1 text-xs font-mono rounded-md bg-miku-base dark:bg-miku-dark-base border border-miku-border-dim dark:border-miku-dark-border text-miku-text-dim dark:text-miku-dark-dim group-hover:border-miku-cyan/30 transition-colors duration-300">
                  {tech}
                </span>
              ))}
            </div>

            {/* CTA Button */}
            {isLiveDemo(project.link) ? (
              /* Live Demo — primary style */
              <a
                href={project.link}
                class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium bg-miku-cyan/10 dark:bg-miku-cyan/15 border border-miku-cyan/30 text-miku-cyan hover:bg-miku-cyan/20 transition-all duration-300"
                target="_blank"
                rel="noopener noreferrer"
                data-lang-key="view-project"
              >
                Live Demo
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ) : (
              /* Source Code — secondary style */
              <a
                href={project.link}
                class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium bg-miku-base dark:bg-miku-dark-base border border-miku-border-dim dark:border-miku-dark-border text-miku-text-main dark:text-miku-dark-text hover:border-miku-cyan/50 transition-all duration-300"
                target="_blank"
                rel="noopener noreferrer"
              >
                Source Code
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
              </a>
            )}
          </article>
        ))
    }
  </div>
</section>
