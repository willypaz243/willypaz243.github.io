---
import profile from '../data/profile.json';
---

<section class="mb-16">
  <h2
    class="text-3xl font-bold mb-8 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
  >
    Skills
  </h2>

  <div class="mb-12">
    <h3 class="text-2xl font-semibold mb-6 text-miku-teal-strong dark:text-miku-cyan">Soft Skills</h3>
    <div class="flex flex-wrap gap-3">
      {
        profile.softSkills.map(skill => (
          <span class="px-4 py-2 bg-miku-surface dark:bg-miku-dark-surface text-miku-text-main dark:text-miku-dark-text rounded-miku shadow-miku-light hover:shadow-miku-dark transition-all transform hover:-translate-y-1 border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-cyan">
            {skill}
          </span>
        ))
      }
    </div>
  </div>

  <div>
    <h3 class="text-2xl font-semibold mb-6 text-miku-teal-strong dark:text-miku-cyan">Technical Skills</h3>
    <div class="flex flex-wrap gap-3">
      {
        profile.technicalSkills.map(skill => (
          <span class="px-4 py-2 bg-miku-surface dark:bg-miku-dark-surface text-miku-text-main dark:text-miku-dark-text rounded-miku shadow-miku-light hover:shadow-miku-dark transition-all transform hover:-translate-y-1 border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-cyan">
            {skill}
          </span>
        ))
      }
    </div>
  </div>
</section>

