---
import profile from '../data/profile.en.json';
---

<section class="mb-16">
  <h2
    id="sk-title"
    class="text-3xl font-bold mb-8 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
  >
    Skills
  </h2>

  <div class="space-y-8">
    {
      Object.entries(profile.skills).map(([category, skills]: [string, any]) => {
        if (typeof skills === 'string') return null;

        const categoryTitle = skills.title || '';
        const categoryExpertise = skills.expertise || '';
        const expertTools = skills.proficient_tools || [];
        const workingTools = skills.familiar_tools || [];

        return (
          <div class="skill-category">
            <div class="flex items-center gap-3 mb-4">
              <h3 id={`sk-${category}_title`} class="text-2xl font-semibold text-miku-teal-strong dark:text-miku-cyan">{categoryTitle}</h3>
              {categoryExpertise && <span class="text-sm text-gray-500 dark:text-gray-400">· {categoryExpertise}</span>}
            </div>

            {expertTools.length > 0 && (
              <div class="mb-4">
                <p data-lang-key="daily-label" class="text-sm text-gray-600 dark:text-gray-400 mb-3">
                  Proficient tools and technologies I use daily
                </p>
                <div class="flex flex-wrap gap-2">
                  {expertTools.map((tool: string) => (
                    <span class="px-3 py-2 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan-dark to-miku-glow dark:to-miku-purple text-white rounded-lg shadow-sm hover:shadow-md transition-all">
                      {tool}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {workingTools.length > 0 && (
              <div>
                <p data-lang-key="familiar-label" class="text-sm text-gray-600 dark:text-gray-400 mb-3">Tools and technologies I'm familiar with</p>
                <div class="flex flex-wrap gap-2">
                  {workingTools.map((tool: string) => (
                    <span class="px-3 py-2 bg-miku-surface dark:bg-miku-dark-surface text-miku-text-main dark:text-miku-dark-text rounded-lg border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-teal-strong dark:hover:border-miku-cyan transition-all">
                      {tool}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })
    }

    {
      profile.skills.soft_skills && profile.skills.soft_skills.length > 0 && (
        <div class="skill-category">
          <h3 id="sf-title" class="text-2xl font-semibold text-miku-teal-strong dark:text-miku-cyan mb-1">Soft Skills</h3>
          <p id="sf-desc" class="text-sm text-gray-600 dark:text-gray-400 mb-4 mt-1">Professional competencies applied in real projects</p>
          <div class="flex flex-wrap gap-2">
            {profile.skills.soft_skills.map(skill => (
              <span class="px-3 py-2 bg-miku-surface dark:bg-miku-dark-surface text-miku-text-main dark:text-miku-dark-text rounded-lg border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-cyan transition-all text-sm">
                {skill}
              </span>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>
