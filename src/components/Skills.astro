---
import profile from '../data/profile.en.json';
---

<section id="skills" class="max-w-4xl mx-auto py-8 animate-fade-in">
  <h2
    id="sk-title"
    class="text-3xl font-bold mb-8 bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text"
  >
    Skills
  </h2>

  <div class="space-y-12 mt-12">
    {
      Object.entries(profile.skills).map(([category, skills]: [string, any]) => {
        if (typeof skills === 'string') return null;

        const categoryTitle = skills.title || '';
        const categoryExpertise = skills.expertise || '';
        const expertTools = skills.proficient_tools || [];
        const workingTools = skills.familiar_tools || [];

        return (
          <div class="skill-category" data-animate>
            <h3
              id={`sk-${category}_title`}
              class="text-2xl font-semibold text-miku-teal-strong dark:text-miku-cyan mb-4"
            >
              {categoryTitle}
              {categoryExpertise && (
                <span class="ml-2 text-sm font-normal text-gray-500 dark:text-gray-400">— {categoryExpertise}</span>
              )}
            </h3>

            <div class="mb-6">
              <p data-lang-key="daily-label" class="text-sm text-miku-text-dim dark:text-miku-dark-dim mb-2 font-medium">
                Proficient tools and technologies I use daily
              </p>
              <div class="flex flex-wrap gap-2">
                {expertTools.map((tool: string) => (
                  <span class="px-3 py-1.5 text-sm rounded-lg bg-miku-cyan/10 dark:bg-miku-cyan/15 text-miku-cyan dark:text-miku-glow border border-miku-cyan/30 dark:border-miku-cyan/25 font-medium hover:border-miku-cyan transition-all">
                    {tool}
                  </span>
                ))}
              </div>
            </div>

            {workingTools.length > 0 && (
              <div class="mb-2">
                <p data-lang-key="familiar-label" class="text-sm text-miku-text-dim dark:text-miku-dark-dim mb-2 font-medium">
                  Tools and technologies I'm familiar with
                </p>
                <div class="flex flex-wrap gap-2">
                  {workingTools.map((tool: string) => (
                    <span class="px-3 py-1.5 text-sm rounded-lg bg-miku-dark-surface/50 dark:bg-white/5 text-miku-text-main dark:text-miku-dark-text border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-cyan transition-all">
                      {tool}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        );
      })
    }

    <div class="skill-category border-t border-miku-border-dim dark:border-miku-dark-border pt-8" data-animate>
      <h3
        id="sf-title"
        class="text-3xl font-bold bg-gradient-to-r from-miku-teal-strong dark:from-miku-cyan to-miku-glow dark:to-miku-magenta text-transparent bg-clip-text mb-6"
      >
        Soft Skills
      </h3>
      <ul class="space-y-4">
        {profile.skills.soft_skills.map(skill => (
          <li class="flex items-start gap-3 text-miku-text-main dark:text-miku-dark-text">
            <span class="mt-1.5 w-2 h-2 rounded-full bg-miku-cyan flex-shrink-0"></span>
            <span>{skill}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
