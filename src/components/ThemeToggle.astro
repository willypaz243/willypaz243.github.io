<script>
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;

  // Check for saved theme preference, otherwise use system preference
  const theme =
    localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

  html.classList.toggle('dark', theme === 'dark');

  themeToggle?.addEventListener('click', () => {
    html.classList.toggle('dark');
    localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
  });
</script>

<button
  id="theme-toggle"
  class="fixed top-4 right-4 p-2 rounded-lg bg-miku-surface dark:bg-miku-dark-surface border border-miku-border-dim dark:border-miku-dark-border hover:border-miku-cyan transition-all duration-300"
  aria-label="Toggle theme"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-6 h-6 hidden dark:block text-miku-cyan"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    style="filter: drop-shadow(0 0 8px rgba(57, 197, 187, 0.6));"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
      style="filter: drop-shadow(0 0 10px rgba(57, 197, 187, 0.8));"></path>
  </svg>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-6 h-6 block dark:hidden text-miku-teal-strong"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    style="filter: drop-shadow(0 2px 6px rgba(0, 163, 150, 0.4));"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    ></path>
  </svg>
</button>

