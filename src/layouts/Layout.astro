---
import ThemeToggle from '../components/ThemeToggle.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Willy Samuel Paz Colque - Portfolio</title>
    <meta
      name="description"
      content="Full Stack Web Developer with over 3 years of experience and nearly a decade of programming expertise."
    />
  </head>
  <body
    class="bg-miku-base dark:bg-miku-dark-base text-miku-text-main dark:text-miku-dark-text transition-colors duration-300"
  >
    <div class="relative">
      <ThemeToggle />
      <div
        class="inset-0 bg-gradient-to-br from-miku-cyan/5 to-miku-glow/5 dark:from-miku-cyan/10 dark:to-miku-glow/10 -z-10"
      >
      </div>
      <slot />
    </div>
  </body>
</html>

<style>
  html {
    font-family: system-ui, sans-serif;
    scroll-padding-top: 2rem;
  }
  body {
    margin: 0;
    min-height: 100vh;
  }
</style>