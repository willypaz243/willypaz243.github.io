---
import DesktopNav from '../components/DesktopNav.astro';
import Navigation from '../components/Navigation.astro';
import profile from '../data/profile.json';
---

<!doctype html>
<html lang={profile.lang || 'en'} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Willy Samuel Paz Colque - Portfolio</title>
    <meta name="description" content={profile.about.description} />
  </head>
  <body
    class="bg-miku-base dark:bg-miku-dark-base text-miku-text-main dark:text-miku-dark-text transition-colors duration-300 pt-[70px]"
  >
    <div class="relative">
      <DesktopNav />
      <slot />
      <Navigation />
    </div>
  </body>
</html>

<style>
  html {
    font-family: system-ui, sans-serif;
    scroll-padding-top: 2rem;
  }
  body {
    margin: 0;
    min-height: 100vh;
  }
</style>
